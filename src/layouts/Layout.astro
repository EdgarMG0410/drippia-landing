---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'Perfecciona tu café con guías paso a paso impulsadas por IA' } = Astro.props;
---

<!doctype html>
<html lang="es" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/logo.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
  </head>
  <body class="bg-ghost-white text-carbon-black font-sans antialiased overflow-x-hidden">
    <slot />
  </body>
</html>
