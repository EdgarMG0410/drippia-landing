---
const values = [
  {
    title: 'Principiantes',
    description: 'Aprende los fundamentos del café de especialidad con recetas probadas y explicaciones claras.'
  },
  {
    title: 'Entusiastas',
    description: 'Perfecciona tu técnica con guías precisas y experimenta con diferentes perfiles de sabor.'
  },
  {
    title: 'Baristas Caseros',
    description: 'Optimiza cada variable de extracción con troubleshooting avanzado y reproduce tus mejores preparaciones.'
  },
  {
    title: 'Profesionales',
    description: 'Documenta recetas para tu cafetería, entrena a tu equipo y mantén estándares de calidad.'
  }
];
---

<section class="py-24 md:py-32 px-6 bg-alabaster-grey">
  <div class="max-w-6xl mx-auto">
    <h2 class="font-display text-5xl md:text-6xl font-bold mb-20 text-center text-carbon-black">
      ¿Para quién es Drippia?
    </h2>

    <div class="grid md:grid-cols-2 gap-12">
      {values.map((value) => (
        <div class="bg-white p-8 rounded-2xl shadow-sm border border-carbon-black/10">
          <h3 class="font-display text-2xl md:text-3xl font-bold mb-4 text-carbon-black">{value.title}</h3>
          <p class="text-lg md:text-xl text-carbon-black/80 leading-relaxed">{value.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>
