---
import Aurora from "./Aurora";
---

<section class="h-screen max-h-dvh bg-linear-to-br from-zinc-900 via-neutral-800 to-stone-900 overflow-x-hidden overflow-y-hidden">
  <!-- Contenedor full width y full height -->
  <div class="relative w-full h-full overflow-hidden">
    <!-- Aurora Background -->
    <div class="absolute inset-0 z-0 w-full h-full">
      <Aurora client:load colorStops={["#a8a8a8","#4a4a4a","#787878"]} amplitude={1.2} blend={0.7} />
    </div>

    <!-- Grid de dos columnas en desktop, una columna en mobile -->
    <div class="relative z-10 h-full flex flex-col lg:grid lg:grid-cols-2 lg:items-center">
      <!-- Columna de texto -->
      <div class="relative z-20 px-4 pt-20 pb-2 sm:px-6 sm:pt-24 sm:pb-4 lg:px-8 lg:py-16 xl:px-24 xl:py-20 flex flex-col justify-center lg:justify-center shrink-0 lg:h-auto order-1">
        <div class="hidden lg:block lg:flex-1"></div>
        <div class="text-center lg:text-left">
          <h1
            class="font-sans text-[3rem] sm:text-5xl md:text-6xl lg:text-9xl font-light mb-3 sm:mb-4 lg:mb-6 leading-[1.10] text-white"
          >
            Prepara café
            <br />
            excepcional
          </h1>

          <p
            class="font-display text-[1rem] sm:text-sm md:text-2xl text-white/90 mb-3 sm:mb-4 lg:mb-8 leading-snug max-w-sm sm:max-w-md lg:max-w-2xl mx-auto lg:mx-0"
          >
            Tu compañero personal para dominar el arte del café de especialidad.
            Guías paso a paso que extraen el máximo potencial de cada grano.
          </p>

          <div class="mb-2 lg:mb-4">
            <p class="text-white text-[0.5rem] sm:text-xs lg:text-lg font-semibold mb-1 sm:mb-2 lg:mb-3 text-center lg:text-left">
                Próximamente
              </p>
            <div class="flex flex-row gap-2 lg:gap-4 mb-2 lg:mb-3 justify-center lg:justify-start">
              <div
                class="bg-black text-white px-4 py-3 lg:px-6 lg:py-4 rounded-lg flex items-center gap-3 border border-white/10"
              >
                <svg class="w-6 h-6 lg:w-7 lg:h-7" fill="currentColor" viewBox="0 0 24 24">
                  <path
                    d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.81-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"
                  ></path>
                </svg>
                <div class="flex flex-col items-start">
                  <span class="text-sm lg:text-lg font-bold -mt-1">App Store</span>
                </div>
              </div>
              <div
                class="bg-black text-white px-4 py-3 lg:px-6 lg:py-4 rounded-lg flex items-center gap-3 border border-white/10"
              >
                <svg class="w-6 h-6 lg:w-7 lg:h-7" fill="currentColor" viewBox="0 0 24 24">
                  <path
                    d="M3,20.5V3.5C3,2.91 3.34,2.39 3.84,2.15L13.69,12L3.84,21.85C3.34,21.6 3,21.09 3,20.5M16.81,15.12L6.05,21.34L14.54,12.85L16.81,15.12M20.16,10.81C20.5,11.08 20.75,11.5 20.75,12C20.75,12.5 20.53,12.9 20.18,13.18L17.89,14.5L15.39,12L17.89,9.5L20.16,10.81M6.05,2.66L16.81,8.88L14.54,11.15L6.05,2.66Z"
                  ></path>
                </svg>
                <div class="flex flex-col items-start">
                  <span class="text-sm lg:text-lg font-bold -mt-1">Google Play</span>
                </div>
              </div>
            </div>
            
            <div class="mt-2 lg:mt-8">
              <p class="text-white/80 text-[0.8rem] sm:text-xs lg:text-base mb-2 lg:mb-4 text-center lg:text-left">
                Accede a la beta exclusiva
              </p>
              
              <form id="beta-form" class="flex flex-row gap-2 max-w-md mx-auto lg:mx-0">
                <input
                  type="email"
                  name="email"
                  placeholder="tu@email.com"
                  class="flex-1 px-3 py-2 lg:px-4 lg:py-3 text-sm rounded-lg bg-white/10 border border-white/20 text-white placeholder-white/50 focus:outline-none focus:ring-2 focus:ring-white/50 focus:border-transparent backdrop-blur-sm"
                  required
                />
                <button
                  type="submit"
                  class="px-4 py-2 lg:px-6 lg:py-3 text-sm lg:text-base bg-white text-carbon-black font-bold rounded-lg hover:scale-105 transition-transform duration-300 whitespace-nowrap"
                >
                  Registrar
                </button>
              </form>
              
              <p id="form-message" class="text-white/50 text-[10px] lg:text-xs mt-2 lg:mt-3 text-left">
                * Cupos limitados
              </p>
            </div>
          </div>
        </div>
        <div class="hidden lg:block lg:flex-1"></div>

        <button
          class="hidden lg:flex text-white/60 text-sm items-center gap-2 hover:text-white transition-colors animate-bounce-slow absolute bottom-5 left-1/2 -translate-x-1/2"
        >
          <svg
            class="w-5 h-5"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M19 14l-7 7m0 0l-7-7m7 7V3"></path>
          </svg>
          Scroll down
        </button>
      </div>

      <!-- Columna de mockups - abajo en mobile, a la derecha en desktop -->
      <div
        class="relative flex-1 lg:relative lg:h-full flex items-end lg:items-center justify-center lg:justify-end order-2"
      >
        <!-- Imagen de mockups de teléfonos -->
        <div
          class="relative w-full h-full flex items-end lg:items-center justify-center lg:justify-end lg:pr-0"
        >
          <picture>
            <source media="(min-width: 1024px)" srcset="/assets/drippia-hero.png" />
            <img 
              src="/assets/hero-mobile.png" 
              alt="Drippia App Mockups" 
              class="w-auto h-[70%] sm:h-[95%] lg:h-[95%] xl:h-full object-contain scale-[1.85] sm:scale-[2.5] lg:scale-150 xl:scale-[1.75]"
            />
          </picture>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  @keyframes fadeIn {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes bounceSlow {
    0%, 100% {
      transform: translateY(0);
    }
    50% {
      transform: translateY(-8px);
    }
  }

  .animate-fade-in {
    animation: fadeIn 800ms ease-out;
  }

  .animate-fade-in-delay {
    animation: fadeIn 800ms ease-out 300ms both;
  }

  .animate-fade-in-delay-2 {
    animation: fadeIn 800ms ease-out 600ms both;
  }

  .animate-bounce-slow {
    animation: bounceSlow 2s ease-in-out infinite;
  }
</style>

<script>
  const form = document.getElementById('beta-form') as HTMLFormElement;
  const message = document.getElementById('form-message') as HTMLParagraphElement;

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    
    const formData = new FormData(form);
    const email = formData.get('email') as string;
    const button = form.querySelector('button[type="submit"]') as HTMLButtonElement;
    const originalText = button.textContent;

    // Deshabilitar botón y mostrar loading
    button.disabled = true;
    button.textContent = 'Enviando...';

    try {
      const response = await fetch('/api/subscribe', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
        },
        body: JSON.stringify({ email }),
      });

      const data = await response.json();

      if (response.ok) {
        message.textContent = '✓ ¡Registro exitoso! Revisa tu email.';
        message.className = 'text-green-400 text-[10px] lg:text-xs mt-2 lg:mt-3 text-left';
        form.reset();
      } else {
        message.textContent = '✗ ' + (data.error || 'Error al registrar');
        message.className = 'text-red-400 text-[10px] lg:text-xs mt-2 lg:mt-3 text-left';
      }
    } catch (error) {
      message.textContent = '✗ Error de conexión. Intenta de nuevo.';
      message.className = 'text-red-400 text-[10px] lg:text-xs mt-2 lg:mt-3 text-left';
    } finally {
      button.disabled = false;
      button.textContent = originalText;
      
      // Restaurar mensaje original después de 5 segundos
      setTimeout(() => {
        message.textContent = '* Cupos limitados';
        message.className = 'text-white/50 text-[10px] lg:text-xs mt-2 lg:mt-3 text-left';
      }, 5000);
    }
  });
</script>
