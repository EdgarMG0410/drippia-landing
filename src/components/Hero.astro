---
import GradientBackground from "./GradientBackground";
---

<section class="h-screen bg-white flex items-center justify-center p-0 lg:p-4">
  <!-- Contenedor interno centrado con altura 100vh - 2rem -->
  <div class="relative w-full h-full lg:h-[calc(100vh-2rem)] lg:rounded-[40px] overflow-hidden border-0 lg:border-4 lg:border-white">
    <!-- Gradient Background -->
    <div class="absolute inset-0 z-0">
      <GradientBackground client:load />
    </div>

    <!-- Grid de dos columnas en desktop, una columna en mobile -->
    <div class="relative z-10 h-full grid grid-cols-1 lg:grid-cols-2 lg:items-center">
      <!-- Columna de texto -->
      <div class="px-6 py-12 lg:px-8 lg:py-16 xl:px-24 xl:py-20 flex flex-col justify-center h-full lg:h-auto order-2 lg:order-1">
        <div class="hidden lg:block lg:flex-1"></div>
        <div class="text-center lg:text-left">
          <h1
            class="font-sans text-5xl md:text-6xl lg:text-9xl font-light mb-6 leading-tight text-white"
          >
            Prepara café
            <br />
            excepcional
          </h1>

          <p
            class="font-display text-lg md:text-2xl text-white/90 mb-8 leading-normal max-w-2xl mx-auto lg:mx-0"
          >
            Tu compañero personal para dominar el arte del café de especialidad.
            Guías paso a paso que extraen el máximo potencial de cada grano.
          </p>

          <div class="flex flex-row gap-2 lg:gap-4 mb-8 justify-center lg:justify-start">
            <button
              class="bg-carbon-black text-white px-4 py-3 lg:px-10 lg:py-5 rounded-xl font-bold text-sm lg:text-base hover:scale-105 transition-transform duration-300 flex items-center justify-center gap-2 lg:gap-3"
            >
              <svg class="w-5 h-5 lg:w-6 lg:h-6" fill="currentColor" viewBox="0 0 24 24">
                <path
                  d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.81-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"
                ></path>
              </svg>
              <span class="hidden sm:inline">App Store</span>
            </button>
            <button
              class="bg-carbon-black text-white px-4 py-3 lg:px-10 lg:py-5 rounded-xl font-bold text-sm lg:text-base hover:scale-105 transition-transform duration-300 flex items-center justify-center gap-2 lg:gap-3"
            >
              <svg class="w-5 h-5 lg:w-6 lg:h-6" fill="currentColor" viewBox="0 0 24 24">
                <path
                  d="M3,20.5V3.5C3,2.91 3.34,2.39 3.84,2.15L13.69,12L3.84,21.85C3.34,21.6 3,21.09 3,20.5M16.81,15.12L6.05,21.34L14.54,12.85L16.81,15.12M20.16,10.81C20.5,11.08 20.75,11.5 20.75,12C20.75,12.5 20.53,12.9 20.18,13.18L17.89,14.5L15.39,12L17.89,9.5L20.16,10.81M6.05,2.66L16.81,8.88L14.54,11.15L6.05,2.66Z"
                ></path>
              </svg>
              <span class="hidden sm:inline">Google Play</span>
            </button>
          </div>
        </div>
        <div class="hidden lg:block lg:flex-1"></div>

        <button
          class="hidden lg:flex text-white/60 text-sm items-center gap-2 hover:text-white transition-colors animate-bounce-slow"
        >
          <svg
            class="w-5 h-5"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M19 14l-7 7m0 0l-7-7m7 7V3"></path>
          </svg>
          Scroll down
        </button>
      </div>

      <!-- Columna de mockups - detrás en mobile, a la derecha en desktop -->
      <div
        class="absolute inset-0 lg:relative lg:h-full flex items-center justify-center lg:justify-end opacity-20 lg:opacity-100 order-1 lg:order-2"
      >
        <!-- Aquí van las imágenes de los teléfonos con perspectiva 3D -->
        <div
          class="relative w-full h-full flex items-center justify-center lg:justify-end lg:pr-8 xl:pr-16"
        >
          <!-- Placeholder para teléfonos -->
          <div class="text-white/10 text-center">
            <div class="flex gap-4 items-center justify-center">
              <div
                class="w-48 h-96 border-4 border-white/10 rounded-[40px] transform rotate-[-15deg] translate-x-8"
              >
              </div>
              <div
                class="w-48 h-96 border-4 border-white/10 rounded-[40px] transform rotate-[5deg] translate-y-8"
              >
              </div>
              <div
                class="w-48 h-96 border-4 border-white/10 rounded-[40px] transform rotate-[15deg] translate-x-[-8px]"
              >
              </div>
            </div>
            <p class="text-sm font-medium mt-8">
              Espacio para mockups de teléfonos
            </p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  @keyframes fadeIn {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes bounceSlow {
    0%, 100% {
      transform: translateY(0);
    }
    50% {
      transform: translateY(-8px);
    }
  }

  .animate-fade-in {
    animation: fadeIn 800ms ease-out;
  }

  .animate-fade-in-delay {
    animation: fadeIn 800ms ease-out 300ms both;
  }

  .animate-fade-in-delay-2 {
    animation: fadeIn 800ms ease-out 600ms both;
  }

  .animate-bounce-slow {
    animation: bounceSlow 2s ease-in-out infinite;
  }
</style>
