<section class="py-24 md:py-32 px-6 bg-carbon-black text-white">
  <div class="max-w-7xl mx-auto">
    <h2 class="font-display text-5xl md:text-6xl lg:text-7xl font-bold mb-20 max-w-4xl leading-tight">
      Esto no es solo una app.
      <span class="text-white/60">Es tu coach personal de café.</span>
    </h2>

    <div class="space-y-32">
      <div class="grid md:grid-cols-2 gap-16 items-center">
        <div>
          <h3 class="font-display text-4xl md:text-5xl font-bold mb-6">Coach IA Personalizado</h3>
          <p class="text-xl md:text-2xl text-white/80 leading-relaxed">
            Recetas personalizadas con IA. Troubleshooting inteligente. Consejos en tiempo real. Powered by Google Gemini.
          </p>
        </div>
        <div class="bg-white/5 rounded-3xl h-80 flex items-center justify-center border border-white/10">
          <span class="text-8xl">🤖</span>
        </div>
      </div>

      <div class="grid md:grid-cols-2 gap-16 items-center">
        <div class="bg-white/5 rounded-3xl h-80 flex items-center justify-center order-2 md:order-1 border border-white/10">
          <span class="text-8xl">⏱️</span>
        </div>
        <div class="order-1 md:order-2">
          <h3 class="font-display text-4xl md:text-5xl font-bold mb-6">Preparaciones Guiadas</h3>
          <p class="text-xl md:text-2xl text-white/80 leading-relaxed">
            V60, Chemex, Aeropress, French Press. Timer integrado, contador de agua, visualización clara de cada paso.
          </p>
        </div>
      </div>

      <div class="grid md:grid-cols-2 gap-16 items-center">
        <div>
          <h3 class="font-display text-4xl md:text-5xl font-bold mb-6">Biblioteca de Cafés</h3>
          <p class="text-xl md:text-2xl text-white/80 leading-relaxed">
            Organiza tus granos con fotos. Origen, varietal, proceso, tueste. Notas de cata e historial completo.
          </p>
        </div>
        <div class="bg-white/5 rounded-3xl h-80 flex items-center justify-center border border-white/10">
          <span class="text-8xl">☕</span>
        </div>
      </div>
    </div>
  </div>
</section>
